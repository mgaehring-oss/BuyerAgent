{
  "mcpServers": {
    "gmail": {
      "command": "npx",
      "args": ["-y", "@gptscript-ai/gmail-oauth-mcp"],
      "env": {
        "GMAIL_OAUTH_CLIENT_ID": "<YOUR_CLIENT_ID>",
        "GMAIL_OAUTH_CLIENT_SECRET": "<YOUR_CLIENT_SECRET>",
        "GMAIL_OAUTH_REFRESH_TOKEN": "<YOUR_REFRESH_TOKEN>"
      }
    }
  }
}
